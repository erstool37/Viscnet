#### Active: basic low-risk filesystem commands
prefix_rule(pattern=["mkdir", "-p"], decision="allow")
prefix_rule(pattern=["cp"], decision="allow")

#### Active: curl metadata and retrieval
# Direct curl invocations are broadly reusable and low risk.
# Use curl as the executable directly so execpolicy can match it. A shell chain
# such as `zsh -lc "curl ... && ..."` is one opaque shell argument; allowing that
# generically would allow arbitrary shell code, so keep follow-up commands split.
prefix_rule(pattern=["curl"], decision="allow")
prefix_rule(pattern=["curl", "-L", "-I", "--max-time", "10", "--connect-timeout", "5"], decision="allow")

#### Active: broadly reusable low-risk inspection commands
prefix_rule(pattern=["find"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["sed", "-n"], decision="allow")
prefix_rule(pattern=["nl", "-ba"], decision="allow")
prefix_rule(pattern=["wc"], decision="allow")
prefix_rule(pattern=["ps"], decision="allow")

#### Active: Git everyday inspection commands
prefix_rule(pattern=["git", ["read-tree", "clean", "reset", "filter-branch"]], decision="forbidden", justification="High-risk git operation; approve case by case.")
prefix_rule(pattern=["git", "push", "--force"], decision="forbidden", justification="Force-push requires explicit approval.")
prefix_rule(pattern=["git", "push", "-f"], decision="forbidden", justification="Force-push requires explicit approval.")
prefix_rule(pattern=["git", "status"], decision="allow")
prefix_rule(pattern=["git", "diff"], decision="allow")
prefix_rule(pattern=["git", "log"], decision="allow")
prefix_rule(pattern=["git", "show"], decision="allow")
prefix_rule(pattern=["git", "ls-files"], decision="allow")

#### Active: project-local setup, compile, and test entrypoints
prefix_rule(pattern=["bash", "scripts/setup.sh"], decision="allow")
prefix_rule(pattern=["bash", "scripts/dev.sh"], decision="allow")
prefix_rule(pattern=["bash", "scripts/run_rebuild_reproduction.sh"], decision="allow")
prefix_rule(pattern=["bash", "scripts/run_transfer_lrhold_then_window30.sh"], decision="allow")

#### Active: project-local Python checks and analysis
prefix_rule(pattern=["python3", "-m", "ruff", "check"], decision="allow")
prefix_rule(pattern=["python3", "scripts/check_rebuild_results.py"], decision="allow")
prefix_rule(pattern=["python3", "scripts/analyze_rebuild_results.py"], decision="allow")
prefix_rule(pattern=["python3", "scripts/post_rebuild_training.py"], decision="allow")
prefix_rule(pattern=["python3", "scripts/require_rebuild_accuracy.py"], decision="allow")
prefix_rule(pattern=["python3", "scripts/build_raw_realvideo_configs.py"], decision="allow")
prefix_rule(pattern=["python3", "scripts/build_real_window_dataset.py"], decision="allow")
prefix_rule(pattern=["python3", "scripts/window21_test_inference.py"], decision="allow")

#### Active: harmless local cleanup
prefix_rule(pattern=["rm", "-f", ".DS_Store"], decision="allow")
prefix_rule(pattern=["rm", "-f", ".codex/write-test.tmp"], decision="allow")
prefix_rule(pattern=["touch", ".codex/write-test.tmp"], decision="allow")
